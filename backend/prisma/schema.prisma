generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model PageView {
  id        Int      @id @default(autoincrement())
  path      String
  referrer  String?
  userAgent String?
  country   String?
  city      String?
  device    String?
  browser   String?
  os        String?
  screenW   Int?
  screenH   Int?
  language  String?
  sessionId String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([sessionId])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
